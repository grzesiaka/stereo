{
  "name": "oyoyo",
  "version": "1.0.0-alpha.6",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='oyoyo'...",
    "build$": "turbo run build --filter='oyoyo'...",
    "test": "vitest test --passWithNoTests"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "composyo": "workspace:",
    "type-fest": "catalog:",
    "vitest": "catalog:",
    "~js": "workspace:"
  }
}
