{
  "name": "vite-plugin-write-to-disk",
  "version": "1.0.0-alpha.0",
  "sideEffects": false,
  "main": "./out/index.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    },
    "./*": "./out/*"
  },
  "scripts": {
    "build": "tsc -p node_modules/~cfg/tsconfig.build.json",
    "dev": "tsc --watch -p node_modules/~cfg/tsconfig.build.json",
    "dev$": "turbo run dev --filter='vite-plugin-write-to-disk'...",
    "build$": "turbo run build --filter='vite-plugin-write-to-disk'...",
    "test": "vitest test --passWithNoTests"
  },
  "devDependencies": {
    "vite": "catalog:",
    "~nodejs": "workspace:"
  },
  "type": "module"
}
