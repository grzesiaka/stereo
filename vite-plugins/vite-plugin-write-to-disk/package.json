{
  "name": "vite-plugin-write-to-disk",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "main": "./out/index.ts",
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='vite-plugin-write-to-disk'...",
    "build$": "turbo run build --filter='vite-plugin-write-to-disk'...",
    "test": "vitest test --passWithNoTests",
    "tsc": "tsc -p node_modules/~cfg/tsconfig.build.json"
  },
  "devDependencies": {
    "vite": "catalog:",
    "~nodejs": "workspace:"
  }
}
