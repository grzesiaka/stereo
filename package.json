{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "stereo",
  "version": "777.777.777",
  "description": "mono stereo",
  "keywords": [],
  "license": "NON-AI-MPL-2.0",
  "author": "",
  "type": "module",
  "scripts": {
    "ci": "pnpm lint && pnpm tsc-ci && pnpm build --affected && pnpm test-ci",
    "build": "turbo run build --ui=stream",
    "tsc": "turbo run tsc --ui=stream -- --noEmit",
    "tsc-ci": "turbo run tsc --affected --ui=stream -- --noEmit",
    "test": "vitest --project unit",
    "test-ci": "CI=true turbo run test-ci --affected --ui=stream",
    "dev": "turbo run dev --ui=tui",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "set-defaults": "node ./__config/src/set-defaults.ts",
    "clear-all": "node ./__config/src/clear-all.ts",
    "set-exports": "node ./__config/src/set-exports.ts",
    "refresh": "pnpm clear-all && pnpm install && pnpm set-defaults && pnpm lint && pnpm set-exports && pnpm tsc && pnpm build && pnpm test-ci"
  },
  "dependencies": {
    "stereo": "link:",
    "vitest": "catalog:",
    "~cfg": "workspace:^",
    "~testing": "workspace:^",
    "~types": "workspace:^"
  },
  "devDependencies": {
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "tsdown": "0.21.7",
    "turbo": "2.8.21",
    "type-fest": "catalog:",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.33.0"
}
