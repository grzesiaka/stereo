{
  "name": "treeo",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "test": "vitest src",
    "dev$": "turbo run dev --filter='treeo'...",
    "build$": "turbo run build --filter='treeo'..."
  },
  "dependencies": {
    "~js": "workspace:"
  },
  "devDependencies": {
    "composyo": "workspace:",
    "type-fest": "catalog:"
  }
}
