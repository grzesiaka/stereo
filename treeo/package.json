{
  "name": "treeo",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    },
    "./*": "./out/*"
  },
  "scripts": {
    "build": "tsc -p node_modules/~cfg/tsconfig.build.json",
    "dev": "tsc --watch -p node_modules/~cfg/tsconfig.build.json",
    "test": "vitest src",
    "dev$": "turbo run dev --filter='treeo'..."
  },
  "dependencies": {
    "~js": "workspace:"
  },
  "devDependencies": {
    "composyo": "workspace:",
    "type-fest": "catalog:"
  }
}
