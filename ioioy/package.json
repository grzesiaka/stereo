{
  "name": "ioioy",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs",
    "./typebox": "./out/typebox/index.mjs",
    "./typebox/*": "./out/typebox/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts ./src/*/*.ts --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='ioioy'...",
    "build$": "turbo run build --filter='ioioy'...",
    "test": "vitest --passWithNoTests",
    "tsc": "tsc --noEmit -p node_modules/~cfg/tsconfig.build.json"
  },
  "devDependencies": {
    "disposyo": "workspace:",
    "jsyoyo": "workspace:",
    "proyij": "workspace:",
    "typebox": "catalog:",
    "xpresyo": "workspace:"
  },
  "peerDependencies": {
    "typebox": "catalog:"
  }
}
