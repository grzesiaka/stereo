{
  "name": "composyo",
  "version": "1.0.0-beta.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*",
    "./o": "./out/compose.mjs",
    "./c": "./out/compose-async.mjs",
    "./p": "./out/pipe.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='composyo'...",
    "test": "vitest test --passWithNoTests",
    "build$": "turbo run build --filter='composyo'..."
  },
  "dependencies": {},
  "devDependencies": {
    "~js": "workspace:"
  }
}
