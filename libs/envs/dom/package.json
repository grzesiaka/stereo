{
  "name": "~dom",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts ./src/*/*.ts --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='~dom'...",
    "build$": "turbo run build --filter='~dom'...",
    "test": "vitest test --passWithNoTests",
    "tsc": "tsc -p node_modules/~cfg/tsconfig.build.json"
  },
  "devDependencies": {
    "@types/web": "0.0.336"
  }
}
