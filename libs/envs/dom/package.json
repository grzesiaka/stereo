{
  "name": "~dom",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.js",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsc -p node_modules/~cfg/tsconfig.build.json",
    "dev": "tsc --watch -p node_modules/~cfg/tsconfig.build.json",
    "dev$": "turbo run dev --filter='~dom'...",
    "build$": "turbo run build --filter='~dom'...",
    "test": "vitest test --passWithNoTests",
    "tsc": "tsc -p node_modules/~cfg/tsconfig.build.json"
  },
  "dependencies": {
    "@types/web": "0.0.336"
  }
}
