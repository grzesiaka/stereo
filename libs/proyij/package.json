{
  "name": "proyij",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='proyij'...",
    "build$": "turbo run build --filter='proyij'...",
    "test": "vitest test --passWithNoTests"
  },
  "devDependencies": {
    "composyo": "workspace:",
    "~js": "workspace:"
  }
}
