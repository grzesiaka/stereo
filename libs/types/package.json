{
  "name": "~types",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts  --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='~types'...",
    "build$": "turbo run build --filter='~types'...",
    "test": "vitest test --passWithNoTests",
    "tsc": "tsc -p node_modules/~cfg/tsconfig.build.json"
  }
}
