{
  "name": "envyo",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": true,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts ./src/*/*.ts !./src/_*.ts !./src/_*/*.ts !./src/*/_*.ts --minify --sourcemap --dts --clean -d=./out",
    "build$": "turbo run build --filter='envyo'...",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='envyo'...",
    "test": "vitest test --passWithNoTests --project unit",
    "test-ci": "vitest test --passWithNoTests --project unit/out",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@types/node": "catalog:",
    "@types/web": "catalog:"
  }
}
