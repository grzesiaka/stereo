{
  "name": "jsyoyo",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs"
  },
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "tsdown ./src/*.ts  --unbundle --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "test": "vitest test --passWithNoTests",
    "dev$": "turbo run dev --filter='jsyoyo'...",
    "build$": "turbo run build --filter='jsyoyo'...",
    "tsc": "tsc -p node_modules/~cfg/tsconfig.build.json"
  },
  "devDependencies": {
    "ififify": "workspace:",
    "objoy": "workspace:",
    "~testing": "workspace:",
    "~types": "workspace:"
  }
}
