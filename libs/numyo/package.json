{
  "name": "numyo",
  "version": "1.0.0-alpha.5",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./out/index.mjs",
    "./*": "./out/*.mjs",
    "./base": "./out/base/index.mjs",
    "./base/*": "./out/base/*.mjs",
    "./compare": "./out/compare/index.mjs",
    "./compare/*": "./out/compare/*.mjs"
  },
  "scripts": {
    "build": "tsdown ./src/*.ts ./src/*/*.ts --minify --sourcemap --dts --clean -d=./out --tsconfig node_modules/~cfg/tsconfig.build.json",
    "dev": "pnpm build --watch",
    "dev$": "turbo run dev --filter='numyo'...",
    "build$": "turbo run build --filter='numyo'...",
    "test": "vitest test --passWithNoTests",
    "tsc": "tsc --noEmit -p node_modules/~cfg/tsconfig.build.json"
  },
  "devDependencies": {
    "~types": "workspace:"
  },
  "peerDependencies": {
    "ts-arithmetic": "^0.1.1",
    "type-fest": "catalog:"
  }
}
