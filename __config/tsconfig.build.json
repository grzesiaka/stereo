{
  "extends": "./tsconfig.dev.json",
  "compilerOptions": {
    // it is assumed to use this config from project's node_modules/dev
    "rootDir": "${configDir}/../..",
    "outDir": "${configDir}/../../out",
    "noUnusedParameters": true,
    "noUnusedLocals": true
  },
  "include": ["${configDir}/../../src", "${configDir}/../../test", "${configDir}/../../*.ts"]
}
